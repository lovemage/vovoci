{
  "name": "VOVOCI",
  "version": "0.1.3",
  "updated_at": "2026-03-26T10:30:00",
  "release_policy": {
    "windows_artifact": "release/VOVOCI-Setup-<version>.exe",
    "portable_artifact": "release/VOVOCI-portable-<version>.zip",
    "checksum_artifacts": [
      "release/VOVOCI-Setup-<version>.exe.sha256",
      "release/VOVOCI-portable-<version>.zip.sha256"
    ],
    "do_not_commit_release_binaries_to_repo": true,
    "publish_target": "GitHub Releases"
  },
  "release_workflow": [
    "1) Update version in app.py (APP_VERSION), installer/vovoci.iss (MyAppVersion), .agent(version), README*.md version section, and website download URL in site/index.html.",
    "2) In WSL, always call Windows packaging script via absolute Windows path (avoid relative path escaping issues).",
    "3) Build installer: powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"C:\\Users\\user\\desktop\\vovoci\\scripts\\package-windows.ps1\" -Version <version>",
    "4) Build portable ZIP: powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"C:\\Users\\user\\desktop\\vovoci\\scripts\\package-windows.ps1\" -Version <version> -PortableOnly",
    "5) Ensure both artifacts exist in release/. If script cleanup removes one file, rebuild in the needed order and restore both before upload.",
    "6) Generate SHA256 in release/: sha256sum VOVOCI-Setup-<version>.exe > VOVOCI-Setup-<version>.exe.sha256 && sha256sum VOVOCI-portable-<version>.zip > VOVOCI-portable-<version>.zip.sha256",
    "7) Commit and push source changes only (no release binaries): app.py, installer/vovoci.iss, .agent, README.md (+ other language READMEs when version/quick-start changed), site/index.html, and related code/docs.",
    "8) Create GitHub Release tag v<version>.",
    "9) Upload 4 assets to release: installer, installer sha256, portable zip, portable sha256.",
    "10) Verify uploaded asset names and release URL after upload."
  ],
  "wsl_powershell_examples": {
    "build_installer": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"C:\\Users\\user\\desktop\\vovoci\\scripts\\package-windows.ps1\" -Version <version>",
    "build_portable": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"C:\\Users\\user\\desktop\\vovoci\\scripts\\package-windows.ps1\" -Version <version> -PortableOnly",
    "build_with_sign": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File \"C:\\Users\\user\\desktop\\vovoci\\scripts\\package-windows.ps1\" -Version <version> -Sign -SignToolPath \"<signtool_path>\" -CertThumbprint \"<thumbprint>\""
  },
  "release_upload_examples": {
    "check_release": "gh release view v<version>",
    "create_release": "gh release create v<version> --title \"VOVOCI v<version>\" --notes \"Windows release v<version>\"",
    "upload_assets": "gh release upload v<version> release/VOVOCI-Setup-<version>.exe release/VOVOCI-Setup-<version>.exe.sha256 release/VOVOCI-portable-<version>.zip release/VOVOCI-portable-<version>.zip.sha256 --clobber",
    "verify_assets": "gh release view v<version> --json url,assets --jq '{url: .url, assets: [.assets[].name]}'"
  },
  "commit_push_examples": {
    "stage_common": "git add app.py installer/vovoci.iss .agent README.md README.zh-TW.md README.zh-CN.md README.ja.md README.ko.md site/index.html",
    "commit": "git commit -m \"release: v<version>\"",
    "push": "git push"
  }
}

